# ====================
# .env — SparkScore SaaS (compatível com backend/setup/settings.py)
# ====================
# Copie para .env e preencha. Nunca faça commit do .env (está no .gitignore).

# ====================
# Django
# ====================
SECRET_KEY=
DEBUG=True
ENVIRONMENT=development
ALLOWED_HOSTS=localhost,127.0.0.1

# Origens do browser (landing). Várias URLs separadas por vírgula.
# CORS_ALLOWED_ORIGINS=https://exemplary-truth-development.up.railway.app
#
# Ou, só para dev no Railway (qualquer subdomínio *.up.railway.app):
# CORS_ALLOW_RAILWAY_PUBLIC=true
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_RAILWAY_PUBLIC=

# ====================
# Banco de dados
# ====================
# Railway PostgreSQL (recomendado): use a URL completa.
# No serviço Django no Railway, o Railway injeta DATABASE_URL (rede privada).
# Na tua máquina (migrate, shell), usa DATABASE_PUBLIC_URL (proxy público do Railway).
# Ordem em settings: DATABASE_URL → DATABASE_PUBLIC_URL → variáveis PG* → SQLite.
#
# Exemplo (valores fictícios):
# DATABASE_URL=postgresql://postgres:senha@postgres.railway.internal:5432/railway
# DATABASE_PUBLIC_URL=postgresql://postgres:senha@interchange.proxy.rlwy.net:25863/railway
#
DATABASE_URL=
DATABASE_PUBLIC_URL=
DB_CONN_MAX_AGE=60
#
# Alternativa manual (sem URL):
PGDATABASE=
PGUSER=
PGPASSWORD=
PGHOST=
PGPORT=

# ====================
# Motor de análise (Core_SinapUm — endpoint HTTP SinapLint interno) — obrigatório para /analyze/
# ====================
# Alinhado ao MrFoo (`Source/mrfoo`): mesma base HTTP do Core, sem path:
#   SINAPUM_CORE_BASE_URL=https://seu-core.exemplo.com
# Se definires só isto (e deixares SINAPLINT_ENGINE_URL vazio), o SaaS usa:
#   {SINAPUM_CORE_BASE_URL}/api/sinaplint/internal/engine/
# MrFoo chama o Core via MCP em POST …/core/tools/<tool>/execute/ (X-SINAPUM-KEY);
# o SinapLint SaaS usa o endpoint HTTP acima (motor), não o registry MCP.
#
# Railway (serviço Django/API): NUNCA uses http://127.0.0.1 nem localhost — isso é o
# próprio container. Usa o URL público HTTPS do serviço Core (ex.: *.up.railway.app)
# ou o hostname privado entre serviços na mesma rede. "Connection refused" no log =
# URL do motor errado ou Core parado.
#
# Alternativa: URL completa do motor (tem prioridade sobre SINAPUM_CORE_BASE_URL):
#   GET|POST …/api/sinaplint/internal/engine/
# Não uses '=' no início (ex.: errado: =http://...); no Railway cola só o URL.
SINAPUM_CORE_BASE_URL=
SINAPLINT_ENGINE_URL=http://127.0.0.1:5000/api/sinaplint/internal/engine/
# Segredo igual ao Core (`SINAPLINT_ENGINE_SHARED_SECRET`). Podes usar só uma destas:
SINAPLINT_ENGINE_API_KEY=
SINAPLINT_ENGINE_SHARED_SECRET=
SINAPLINT_ENGINE_TIMEOUT=120

# ====================
# Redis (opcional / futuro)
# ====================
REDIS_URL=
REDIS_PASSWORD=

# ====================
# Email (opcional / futuro)
# ====================
EMAIL_PROVIDER=console
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# ====================
# Sentry (opcional)
# ====================
SENTRY_DSN=

# ====================
# Railway (preenchido pelo Railway em deploy; ignorar em local)
# ====================
# PORT=
# RAILWAY_PUBLIC_DOMAIN=
# RAILWAY_ENVIRONMENT=
# RAILWAY_GIT_COMMIT_SHA=
